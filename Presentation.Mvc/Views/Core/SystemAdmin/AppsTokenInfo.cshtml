@{
    ViewData["Title"] = "Apps Token Info Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Apps Token Info Management</h1>
        <p class="page-header__subtitle">Phase 6 System Setup module for managing apps token info records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Apps Token Info</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAppsTokenInfo" class="btn btn--primary">Add Apps Token Info</button>
        <button type="button" id="btnRefreshAppsTokenInfo" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="appsTokenInfoGrid"></div>
</section>

<div id="appsTokenInfoWindow" style="display:none;">
    <form id="appsTokenInfoForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAppsTokenInfo" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAppsTokenInfo" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/appstokeninfo/appstokeninfoSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/appstokeninfo/appstokeninfoSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/appstokeninfo/appstokeninfoDetails.js" asp-append-version="true"></script>
}
