@{
    ViewData["Title"] = "Approver History Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Approver History Management</h1>
        <p class="page-header__subtitle">Phase 1 System Setup module for managing approver history records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Approver History</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddApproverHistory" class="btn btn--primary">Add Approver History</button>
        <button type="button" id="btnRefreshApproverHistory" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="approverHistoryGrid"></div>
</section>

<div id="approverHistoryWindow" style="display:none;">
    <form id="approverHistoryForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelApproverHistory" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveApproverHistory" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/approverhistory/approverhistorySettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/approverhistory/approverhistorySummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/approverhistory/approverhistoryDetails.js" asp-append-version="true"></script>
}
