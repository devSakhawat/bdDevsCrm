{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "Jwt": {
      "SecretKey": "your-super-secret-key-here",
      "Issuer": "bdDevsCrm",
      "Audience": "bdDevsCrm-clients",
      "AccessTokenExpiryMinutes": 60,
      "RefreshTokenExpiryDays": 7
    },
    "Password": {
      "SaltRounds": 12,
      "MinLength": 8,
      "MaxLength": 128,
      "MaxWrongAttempts": 5,
      "ExpiryDays": 90
    },
    "Cache": {
      "EnableDistributedCache": true,
      "UserCacheMinutes": 30,
      "MenuCacheMinutes": 60,
      "StaticDataHours": 24
    },
    "Audit": {
      "EnableAuditMiddleware": true,
      "QueueCapacity": 1000,
      "BatchSize": 50,
      "FlushIntervalSeconds": 5
    }
  }
}
