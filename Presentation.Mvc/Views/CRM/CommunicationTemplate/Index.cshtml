@{
    ViewData["Title"] = "Communication Template Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Communication Template Management</h1>
        <p class="page-header__subtitle">Education CRM master data module for managing communication template records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Communication Template</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddCommunicationTemplate" class="btn btn--primary">Add Communication Template</button>
        <button type="button" id="btnRefreshCommunicationTemplate" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="communicationTemplateGrid"></div>
</section>

<div id="communicationTemplateWindow" style="display:none;">
    <form id="communicationTemplateForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelCommunicationTemplate" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveCommunicationTemplate" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationtemplate/communicationTemplateSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationtemplate/communicationTemplateSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationtemplate/communicationTemplateDetails.js" asp-append-version="true"></script>
}
