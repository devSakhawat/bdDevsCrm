@{
    ViewData["Title"] = "Communication Log";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Communication Log</h1>
        <p class="page-header__subtitle">CRM v1 module for tracking communication activities.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Communication Log</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddCommunicationLog" class="btn btn--primary">Log Activity</button>
        <button type="button" id="btnRefreshCommunicationLog" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="communicationLogGrid"></div>
</section>

<div id="communicationLogWindow" style="display:none;">
    <form id="communicationLogForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelCommunicationLog" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveCommunicationLog" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationlog/communicationLogSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationlog/communicationLogSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationlog/communicationLogDetails.js" asp-append-version="true"></script>
}
