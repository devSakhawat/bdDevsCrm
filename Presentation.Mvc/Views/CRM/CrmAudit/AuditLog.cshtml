@{
    ViewData["Title"] = "CRM Audit Log";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">CRM Audit Log</h1>
        <p class="page-header__subtitle">View all CRM module audit trail — who did what and when.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Audit Log</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnRefreshAuditLog" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="crmAuditLogGrid"></div>
</section>

@section Scripts {
    <script src="~/js/modules/crm/crmaudit/crmAuditLogDashboard.js" asp-append-version="true"></script>
}
