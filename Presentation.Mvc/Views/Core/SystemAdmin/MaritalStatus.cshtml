@{
    ViewData["Title"] = "Marital Status Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Marital Status Management</h1>
        <p class="page-header__subtitle">Phase 1 System Setup module for managing marital status records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Marital Status</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddMaritalStatus" class="btn btn--primary">Add Marital Status</button>
        <button type="button" id="btnRefreshMaritalStatus" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="maritalStatusGrid"></div>
</section>

<div id="maritalStatusWindow" style="display:none;">
    <form id="maritalStatusForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelMaritalStatus" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveMaritalStatus" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/maritalstatus/maritalstatusSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/maritalstatus/maritalstatusSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/maritalstatus/maritalstatusDetails.js" asp-append-version="true"></script>
}
