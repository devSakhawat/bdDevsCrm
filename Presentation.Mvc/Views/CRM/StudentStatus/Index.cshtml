@{
    ViewData["Title"] = "Student Status Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Student Status Management</h1>
        <p class="page-header__subtitle">CRM v1 module for managing Student Status records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Student Status</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddStudentStatus" class="btn btn--primary">Add Student Status</button>
        <button type="button" id="btnRefreshStudentStatus" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="studentStatusGrid"></div>
</section>

<div id="studentStatusWindow" style="display:none;">
    <form id="studentStatusForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelStudentStatus" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveStudentStatus" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/studentstatus/studentStatusSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/studentstatus/studentStatusSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/studentstatus/studentStatusDetails.js" asp-append-version="true"></script>
}
