@{
    ViewData["Title"] = "Access Restriction Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Access Restriction Management</h1>
        <p class="page-header__subtitle">Phase 1 System Setup module for managing access restriction records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Access Restriction</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAccessRestriction" class="btn btn--primary">Add Access Restriction</button>
        <button type="button" id="btnRefreshAccessRestriction" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="accessRestrictionGrid"></div>
</section>

<div id="accessRestrictionWindow" style="display:none;">
    <form id="accessRestrictionForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAccessRestriction" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAccessRestriction" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/accessrestriction/accessrestrictionSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/accessrestriction/accessrestrictionSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/accessrestriction/accessrestrictionDetails.js" asp-append-version="true"></script>
}
