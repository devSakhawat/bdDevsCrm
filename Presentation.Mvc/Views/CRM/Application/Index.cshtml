@{
    ViewData["Title"] = "Application Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Application Management</h1>
        <p class="page-header__subtitle">Manage rebuilt student applications, linked conditions/documents, and kanban status flow.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Application</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddApplication" class="btn btn--primary">Add Application</button>
        <button type="button" id="btnRefreshApplication" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="applicationGrid"></div>
</section>

<section class="dashboard-grid dashboard-grid--two-column mt-16">
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Application Status Board</h3>
            <p class="card__subtitle">Kanban-style view of current applications by status.</p>
        </div>
        <div id="applicationKanbanBoard" class="kanban-board"></div>
    </div>
    <div class="card">
        <div class="card__header">
            <h3 class="card__title">Application Workspace</h3>
            <p class="card__subtitle">Conditions, linked documents, and timeline for the selected application.</p>
        </div>
        <div id="applicationWorkspaceTabStrip">
            <ul>
                <li class="k-state-active">Basic Info</li>
                <li>Conditions</li>
                <li>Documents</li>
                <li>Scholarships</li>
                <li>Visa</li>
                <li>Payments</li>
                <li>Timeline</li>
            </ul>
            <div><div id="applicationBasicPanel" class="detail-panel empty-state">Select an application to inspect.</div></div>
            <div><div id="applicationConditionsPanel" class="detail-panel empty-state">Select an application to view conditions.</div></div>
            <div><div id="applicationDocumentsPanel" class="detail-panel empty-state">Select an application to view linked documents.</div></div>
            <div><div id="applicationScholarshipPanel" class="detail-panel empty-state">Select an application to manage scholarships.</div></div>
            <div><div id="applicationVisaPanel" class="detail-panel empty-state">Select an application to manage visa processing.</div></div>
            <div><div id="applicationPaymentsPanel" class="detail-panel empty-state">Select an application to manage payments.</div></div>
            <div><div id="applicationTimelinePanel" class="timeline-panel empty-state">Select an application to view timeline.</div></div>
        </div>
    </div>
</section>

<div id="applicationWindow" style="display:none;">
    <form id="applicationForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelApplication" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveApplication" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/application/applicationSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/application/applicationSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/application/applicationDetails.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/application/applicationPage.js" asp-append-version="true"></script>
}
