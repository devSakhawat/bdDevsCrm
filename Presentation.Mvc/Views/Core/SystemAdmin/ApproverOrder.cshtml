@{
    ViewData["Title"] = "Approver Order Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Approver Order Management</h1>
        <p class="page-header__subtitle">Phase 3 System Setup module for managing approver order records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Approver Order</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddApproverOrder" class="btn btn--primary">Add Approver Order</button>
        <button type="button" id="btnRefreshApproverOrder" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="approverOrderGrid"></div>
</section>

<div id="approverOrderWindow" style="display:none;">
    <form id="approverOrderForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelApproverOrder" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveApproverOrder" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/approverorder/approverorderSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/approverorder/approverorderSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/approverorder/approverorderDetails.js" asp-append-version="true"></script>
}
