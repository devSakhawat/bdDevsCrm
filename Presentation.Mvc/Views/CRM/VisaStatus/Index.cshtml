@{
    ViewData["Title"] = "Visa Status Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Visa Status Management</h1>
        <p class="page-header__subtitle">Education CRM master data module for managing visa status records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Visa Status</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddVisaStatus" class="btn btn--primary">Add Visa Status</button>
        <button type="button" id="btnRefreshVisaStatus" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="visaStatusGrid"></div>
</section>

<div id="visaStatusWindow" style="display:none;">
    <form id="visaStatusForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelVisaStatus" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveVisaStatus" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/visastatus/visaStatusSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/visastatus/visaStatusSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/visastatus/visaStatusDetails.js" asp-append-version="true"></script>
}
