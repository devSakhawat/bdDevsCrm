@{
    ViewData["Title"] = "Document Access Log Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Document Access Log Management</h1>
        <p class="page-header__subtitle">Review and maintain DMS document access trail records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">DMS</span>
            <span class="breadcrumb__item is-current">Document Access Log</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddDocumentAccessLog" class="btn btn--primary">Add Access Log</button>
        <button type="button" id="btnRefreshDocumentAccessLog" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="documentAccessLogGrid"></div>
</section>

<div id="documentAccessLogWindow" style="display:none;">
    <form id="documentAccessLogForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelDocumentAccessLog" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveDocumentAccessLog" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/documentaccesslog/documentAccessLogSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/documentaccesslog/documentAccessLogSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/documentaccesslog/documentAccessLogDetails.js" asp-append-version="true"></script>
}
