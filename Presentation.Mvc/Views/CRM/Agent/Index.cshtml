@{
    ViewData["Title"] = "Agent Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Agent Management</h1>
        <p class="page-header__subtitle">CRM v1 module for managing Agent records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Agent</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAgent" class="btn btn--primary">Add Agent</button>
        <button type="button" id="btnRefreshAgent" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="agentGrid"></div>
</section>

<div id="agentWindow" style="display:none;">
    <form id="agentForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAgent" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAgent" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/agent/agentSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/agent/agentSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/agent/agentDetails.js" asp-append-version="true"></script>
}
