@{
    ViewData["Title"] = "Audit Trail Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Audit Trail Management</h1>
        <p class="page-header__subtitle">Phase 5 System Setup module for managing audit trail records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Audit Trail</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAuditTrail" class="btn btn--primary">Add Audit Trail</button>
        <button type="button" id="btnRefreshAuditTrail" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="auditTrailGrid"></div>
</section>

<div id="auditTrailWindow" style="display:none;">
    <form id="auditTrailForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAuditTrail" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAuditTrail" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/audittrail/audittrailSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/audittrail/audittrailSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/audittrail/audittrailDetails.js" asp-append-version="true"></script>
}
