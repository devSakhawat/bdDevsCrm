@{
    ViewData["Title"] = "File Update History Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">File Update History Management</h1>
        <p class="page-header__subtitle">Track entity file replacements, versions, and update reasons.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">DMS</span>
            <span class="breadcrumb__item is-current">File Update History</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddFileUpdateHistory" class="btn btn--primary">Add File Update History</button>
        <button type="button" id="btnRefreshFileUpdateHistory" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="fileUpdateHistoryGrid"></div>
</section>

<div id="fileUpdateHistoryWindow" style="display:none;">
    <form id="fileUpdateHistoryForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelFileUpdateHistory" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveFileUpdateHistory" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/fileupdatehistory/fileUpdateHistorySettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/fileupdatehistory/fileUpdateHistorySummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/fileupdatehistory/fileUpdateHistoryDetails.js" asp-append-version="true"></script>
}
