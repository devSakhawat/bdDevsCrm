@{
    ViewData["Title"] = "Applicant Reference Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Applicant Reference Management</h1>
        <p class="page-header__subtitle">Phase 3 applicant detail module for reference maintenance.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Applicant Reference</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddApplicantReference" class="btn btn--primary">Add Applicant Reference</button>
        <button type="button" id="btnRefreshApplicantReference" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="applicantReferenceGrid"></div>
</section>

<div id="applicantReferenceWindow" style="display:none;">
    <form id="applicantReferenceForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelApplicantReference" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveApplicantReference" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/applicantreference/applicantReferenceSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/applicantreference/applicantReferenceSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/applicantreference/applicantReferenceDetails.js" asp-append-version="true"></script>
}
