@{
    ViewData["Title"] = "Communication Type Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Communication Type Management</h1>
        <p class="page-header__subtitle">Education CRM master data module for managing communication type records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Communication Type</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddCommunicationType" class="btn btn--primary">Add Communication Type</button>
        <button type="button" id="btnRefreshCommunicationType" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="communicationTypeGrid"></div>
</section>

<div id="communicationTypeWindow" style="display:none;">
    <form id="communicationTypeForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelCommunicationType" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveCommunicationType" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationtype/communicationTypeSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationtype/communicationTypeSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/communicationtype/communicationTypeDetails.js" asp-append-version="true"></script>
}
