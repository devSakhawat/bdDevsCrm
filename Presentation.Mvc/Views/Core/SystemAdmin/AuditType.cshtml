@{
    ViewData["Title"] = "Audit Type Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Audit Type Management</h1>
        <p class="page-header__subtitle">Phase 1 System Setup module for managing audit type records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Audit Type</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAuditType" class="btn btn--primary">Add Audit Type</button>
        <button type="button" id="btnRefreshAuditType" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="auditTypeGrid"></div>
</section>

<div id="auditTypeWindow" style="display:none;">
    <form id="auditTypeForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAuditType" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAuditType" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/audittype/audittypeSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/audittype/audittypeSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/audittype/audittypeDetails.js" asp-append-version="true"></script>
}
