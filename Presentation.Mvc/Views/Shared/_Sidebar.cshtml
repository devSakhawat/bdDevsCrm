<aside class="app-sidebar" id="appSidebar" aria-label="Primary navigation">
    <div class="app-sidebar__toolbar">
        <label class="app-sidebar__search" for="sidebarMenuSearch">
            <span class="app-sidebar__search-label">Menu</span>
            <input id="sidebarMenuSearch"
                   class="app-sidebar__search-input"
                   type="search"
                   placeholder="Search menu"
                   autocomplete="off"
                   data-sidebar-search
                   disabled />
        </label>
    </div>

    <div class="app-sidebar__menu" id="sidebarMenu" data-sidebar-menu>
        <div class="app-sidebar__state" data-sidebar-state="loading">
            <p class="app-sidebar__state-message">Loading menu...</p>
        </div>

        <div class="app-sidebar__state is-hidden" data-sidebar-state="empty">
            <p class="app-sidebar__state-message" data-sidebar-empty-message>No menu available.</p>
        </div>

        <div class="app-sidebar__state is-hidden" data-sidebar-state="error">
            <p class="app-sidebar__state-message" data-sidebar-error-message>Unable to load menu.</p>
            <div class="app-sidebar__state-actions">
                <button type="button" class="app-sidebar__action" data-sidebar-retry>Retry</button>
                <a class="app-sidebar__action app-sidebar__action--link is-hidden" asp-controller="Account" asp-action="Login" data-sidebar-login>Go to login</a>
            </div>
        </div>

        <div class="app-sidebar__content is-hidden" data-sidebar-content></div>
    </div>
</aside>
