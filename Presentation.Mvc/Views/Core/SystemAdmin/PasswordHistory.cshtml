@{
    ViewData["Title"] = "Password History Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Password History Management</h1>
        <p class="page-header__subtitle">Phase 2 System Setup module for managing password history records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Password History</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddPasswordHistory" class="btn btn--primary">Add Password History</button>
        <button type="button" id="btnRefreshPasswordHistory" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="passwordHistoryGrid"></div>
</section>

<div id="passwordHistoryWindow" style="display:none;">
    <form id="passwordHistoryForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelPasswordHistory" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSavePasswordHistory" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/passwordhistory/passwordhistorySettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/passwordhistory/passwordhistorySummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/passwordhistory/passwordhistoryDetails.js" asp-append-version="true"></script>
}
