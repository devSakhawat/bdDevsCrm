@{
    ViewData["Title"] = "Audit Log Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Audit Log Management</h1>
        <p class="page-header__subtitle">Phase 5 System Setup module for managing audit log records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Audit Log</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAuditLog" class="btn btn--primary">Add Audit Log</button>
        <button type="button" id="btnRefreshAuditLog" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="auditLogGrid"></div>
</section>

<div id="auditLogWindow" style="display:none;">
    <form id="auditLogForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAuditLog" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAuditLog" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/auditlog/auditlogSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/auditlog/auditlogSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/auditlog/auditlogDetails.js" asp-append-version="true"></script>
}
