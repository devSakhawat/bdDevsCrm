@{
    ViewData["Title"] = "Intake Month Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Intake Month Management</h1>
        <p class="page-header__subtitle">Phase 1 CRM setup module for managing intake month records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Intake Month</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddIntakeMonth" class="btn btn--primary">Add Intake Month</button>
        <button type="button" id="btnRefreshIntakeMonth" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="intakeMonthGrid"></div>
</section>

<div id="intakeMonthWindow" style="display:none;">
    <form id="intakeMonthForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelIntakeMonth" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveIntakeMonth" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/intakemonth/intakeMonthSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/intakemonth/intakeMonthSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/intakemonth/intakeMonthDetails.js" asp-append-version="true"></script>
}
