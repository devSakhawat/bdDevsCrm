<header class="app-header">
    <div class="app-header__left">
        <button id="sidebarToggle" class="icon-button icon-button--ghost" type="button" aria-label="Toggle sidebar">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <a class="app-brand" asp-controller="Home" asp-action="Index">
            <span class="app-brand__logo">bd</span>
            <span class="app-brand__text">
                <strong>bdDevsCrm</strong>
                <small>HRIS Workspace</small>
            </span>
        </a>
    </div>

    <div class="app-header__center">
        <label class="app-search" for="globalSearch">
            <span class="app-search__icon" aria-hidden="true">⌕</span>
            <input id="globalSearch" class="app-search__input" type="search" placeholder="Search employee, module or action..." />
        </label>
    </div>

    <div class="app-header__right">
        <button class="icon-button" type="button" aria-label="Notifications" data-demo-action="notifications">
            <span aria-hidden="true">🔔</span>
            <span class="icon-button__badge">5</span>
        </button>
        <button class="icon-button" type="button" aria-label="Quick settings" data-demo-action="settings">
            <span aria-hidden="true">⚙</span>
        </button>
        <button class="app-user" type="button" data-demo-action="profile">
            <span class="app-user__avatar">SA</span>
            <span class="app-user__meta">
                <strong>System Admin</strong>
                <small>HRIS Control Room</small>
            </span>
        </button>
        <button class="icon-button" type="button" aria-label="Logout" id="btnLogout" title="Logout">
            <span aria-hidden="true">🚪</span>
        </button>
    </div>
</header>

<script>
    // Logout button handler
    document.addEventListener('DOMContentLoaded', function() {
        const btnLogout = document.getElementById('btnLogout');
        if (btnLogout && window.AuthManager) {
            btnLogout.addEventListener('click', function() {
                if (confirm('Are you sure you want to logout?')) {
                    window.AuthManager.logout();
                }
            });
        }
    });
</script>
