@{
    ViewData["Title"] = "Agent Lead Assignment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Agent Lead Assignment</h1>
        <p class="page-header__subtitle">CRM v1 module for managing agent-to-lead assignments.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Agent Lead</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAgentLead" class="btn btn--primary">Assign Lead</button>
        <button type="button" id="btnRefreshAgentLead" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="agentLeadGrid"></div>
</section>

<div id="agentLeadWindow" style="display:none;">
    <form id="agentLeadForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAgentLead" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAgentLead" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/agentlead/agentLeadSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/agentlead/agentLeadSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/agentlead/agentLeadDetails.js" asp-append-version="true"></script>
}
