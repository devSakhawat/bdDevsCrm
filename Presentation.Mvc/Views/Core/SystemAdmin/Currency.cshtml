@{
    ViewData["Title"] = "Currency Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Currency Management</h1>
        <p class="page-header__subtitle">Phase 1 System Setup module for managing currency records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Currency</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddCurrency" class="btn btn--primary">Add Currency</button>
        <button type="button" id="btnRefreshCurrency" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="currencyGrid"></div>
</section>

<div id="currencyWindow" style="display:none;">
    <form id="currencyForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelCurrency" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveCurrency" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/currency/currencySettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/currency/currencySummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/currency/currencyDetails.js" asp-append-version="true"></script>
}
