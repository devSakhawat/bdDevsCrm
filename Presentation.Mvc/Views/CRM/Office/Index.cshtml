@{
    ViewData["Title"] = "Office Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Office Management</h1>
        <p class="page-header__subtitle">CRM v1 module for managing Office records.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Office</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddOffice" class="btn btn--primary">Add Office</button>
        <button type="button" id="btnRefreshOffice" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="officeGrid"></div>
</section>

<div id="officeWindow" style="display:none;">
    <form id="officeForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelOffice" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveOffice" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/office/officeSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/office/officeSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/office/officeDetails.js" asp-append-version="true"></script>
}
