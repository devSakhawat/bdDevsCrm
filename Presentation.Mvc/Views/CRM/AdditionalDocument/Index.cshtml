@{
    ViewData["Title"] = "Additional Document Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Additional Document Management</h1>
        <p class="page-header__subtitle">Phase 5 final review module for supporting document maintenance.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Additional Document</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddAdditionalDocument" class="btn btn--primary">Add Additional Document</button>
        <button type="button" id="btnRefreshAdditionalDocument" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="additionalDocumentGrid"></div>
</section>

<div id="additionalDocumentWindow" style="display:none;">
    <form id="additionalDocumentForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelAdditionalDocument" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveAdditionalDocument" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/additionaldocument/additionalDocumentSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/additionaldocument/additionalDocumentSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/additionaldocument/additionalDocumentDetails.js" asp-append-version="true"></script>
}
