<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="bdDevsCrm - Enterprise CRM & HRIS" />
    <meta name="app-base-url" content="@Url.Content("~/")" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " | bdDevsCrm" : "bdDevsCrm")</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />

    <!-- Kendo UI Styles (Uncomment after adding Kendo UI files to wwwroot/lib/kendo_2024_q4/) -->
    @* <link rel="stylesheet" href="~/lib/kendo_2024_q4/css/kendo.common.min.css" /> *@
    @* <link rel="stylesheet" href="~/lib/kendo_2024_q4/css/kendo.default.min.css" /> *@
    @* <link rel="stylesheet" href="~/css/kendo-override.css" asp-append-version="true" /> *@

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="app-shell">
    <div id="loading-overlay" class="loading-overlay is-hidden" aria-live="polite" aria-hidden="true">
        <div class="loading-overlay__content">
            <div class="spinner"></div>
            <p class="loading-overlay__text">Loading...</p>
        </div>
    </div>

    <div id="toast-container" class="toast-container" aria-live="polite" aria-atomic="true"></div>

    @await Html.PartialAsync("_Header")
    <div class="app-shell__frame">
        @await Html.PartialAsync("_Sidebar")

        <main class="app-shell__main" id="mainContent" role="main">
            @await Html.PartialAsync("_PageHeader")
            <div class="content-zone">
                @RenderBody()
            </div>
            @await Html.PartialAsync("_Footer")
        </main>
    </div>

    @await Html.PartialAsync("_ModalConfirm")
    @await Html.PartialAsync("_ModalDynamic")

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Kendo UI JavaScript (Uncomment after adding Kendo UI files to wwwroot/lib/kendo_2024_q4/) -->
    @* <script src="~/lib/kendo_2024_q4/js/kendo.all.min.js"></script> *@

    <script src="~/js/core/app.config.js" asp-append-version="true"></script>
    <script src="~/js/core/app.constants.js" asp-append-version="true"></script>
    <script src="~/js/core/app.api.js" asp-append-version="true"></script>
    <script src="~/js/core/app.auth.js" asp-append-version="true"></script>
    <script src="~/js/core/app.session.js" asp-append-version="true"></script>
    <script src="~/js/core/app.loader.js" asp-append-version="true"></script>
    <script src="~/js/core/app.toast.js" asp-append-version="true"></script>
    <script src="~/js/core/app.modal.js" asp-append-version="true"></script>
    <script src="~/js/core/app.grid.js" asp-append-version="true"></script>
    <script src="~/js/core/app.form.js" asp-append-version="true"></script>
    <script src="~/js/core/app.sidebar.js" asp-append-version="true"></script>
    <script src="~/js/core/app.core.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
