@{
    ViewData["Title"] = "CRM KPI Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">CRM KPI Dashboard</h1>
        <p class="page-header__subtitle">Track key performance indicators — leads, conversions, applications, enrolments, and revenue vs targets.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">KPI Dashboard</span>
        </div>
    </div>
    <div class="page-header__actions">
        <label for="kpiYear" class="form-label" style="margin-right:.5rem;">Year</label>
        <input type="number" id="kpiYear" class="form-input" style="width:90px;" min="2020" max="2035" />
        <label for="kpiMonth" class="form-label" style="margin:.0 .5rem 0 1rem;">Month</label>
        <select id="kpiMonth" class="form-select" style="width:130px;">
            <option value="">All</option>
            <option value="1">January</option>
            <option value="2">February</option>
            <option value="3">March</option>
            <option value="4">April</option>
            <option value="5">May</option>
            <option value="6">June</option>
            <option value="7">July</option>
            <option value="8">August</option>
            <option value="9">September</option>
            <option value="10">October</option>
            <option value="11">November</option>
            <option value="12">December</option>
        </select>
        <button type="button" id="btnLoadKpi" class="btn btn--primary" style="margin-left:1rem;">Load</button>
    </div>
</section>

<section class="dashboard-kpi-row" id="kpiSummaryCards">
    <div class="kpi-card">
        <div class="kpi-card__label">Lead Target</div>
        <div class="kpi-card__value" id="kpiLeadTarget">—</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card__label">Conversion Target</div>
        <div class="kpi-card__value" id="kpiConversionTarget">—</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card__label">Application Target</div>
        <div class="kpi-card__value" id="kpiApplicationTarget">—</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card__label">Enrolment Target</div>
        <div class="kpi-card__value" id="kpiEnrolmentTarget">—</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-card__label">Revenue Target</div>
        <div class="kpi-card__value" id="kpiRevenueTarget">—</div>
    </div>
</section>

<section class="table-shell" style="margin-top:1.5rem;">
    <h2 class="section-title">Branch KPI Targets</h2>
    <div id="kpiBranchTargetGrid"></div>
</section>

@section Scripts {
    <script src="~/js/modules/crm/crmkpi/crmKpiDashboard.js" asp-append-version="true"></script>
}
