@{
    ViewData["Title"] = "Document Tag Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Document Tag Management</h1>
        <p class="page-header__subtitle">Maintain reusable tags for DMS document classification.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">DMS</span>
            <span class="breadcrumb__item is-current">Document Tag</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddDocumentTag" class="btn btn--primary">Add Document Tag</button>
        <button type="button" id="btnRefreshDocumentTag" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="documentTagGrid"></div>
</section>

<div id="documentTagWindow" style="display:none;">
    <form id="documentTagForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelDocumentTag" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveDocumentTag" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/documenttag/documentTagSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/documenttag/documentTagSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/dms/documenttag/documentTagDetails.js" asp-append-version="true"></script>
}
