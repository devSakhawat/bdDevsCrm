@{
    ViewData["Title"] = "Company Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Company Management</h1>
        <p class="page-header__subtitle">Standards-compliant company setup and profile maintenance for System Admin.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">Company</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddCompany" class="btn btn--primary">Add Company</button>
        <button type="button" id="btnRefreshCompany" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="companyGrid"></div>
</section>

<div id="companyWindow" style="display:none;">
    <form id="companyForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelCompany" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSaveCompany" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/company/companySettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/company/companySummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/company/companyDetails.js" asp-append-version="true"></script>
}
