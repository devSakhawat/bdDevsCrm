@{
    ViewData["Title"] = "System Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">System Settings</h1>
        <p class="page-header__subtitle">Centralized company-level configuration using the current System Admin UI standard.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">Core</span>
            <span class="breadcrumb__item">System Admin</span>
            <span class="breadcrumb__item is-current">System Settings</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnRefreshSystemSettings" class="btn btn--secondary">Refresh</button>
        <button type="button" id="btnSaveSystemSettings" class="btn btn--primary">Save Settings</button>
    </div>
</section>

<section class="content-stack">
    <article class="info-card">
        <div class="form-layout form-layout--inline">
            <div class="form-group">
                <label for="systemSettingsCompany">Company</label>
                <input id="systemSettingsCompany" />
            </div>
            <div class="form-group form-group--span-2">
                <label for="systemSettingsStatus">Status</label>
                <input id="systemSettingsStatus" class="app-input" readonly placeholder="Choose a company to load settings" />
            </div>
        </div>
    </article>

    <article class="info-card">
        <div class="info-card__header">
            <h2 class="info-card__title">Assembly Information</h2>
            <p class="info-card__text">Read-only application metadata returned by the current backend service.</p>
        </div>
        <div id="assemblyInfoPanel" class="card-grid card-grid--3"></div>
    </article>

    <article class="info-card">
        <div class="info-card__header">
            <h2 class="info-card__title">Configuration</h2>
            <p class="info-card__text">Update settings after selecting a company. All fields below map directly to <code>SystemSettingsDto</code>.</p>
        </div>
        <form id="systemSettingsForm" class="content-stack"></form>
    </article>
</section>

@section Scripts {
    <script src="~/js/modules/core/systemsettings/systemsettingsSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/systemsettings/systemsettingsSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/core/systemsettings/systemsettingsDetails.js" asp-append-version="true"></script>
}
