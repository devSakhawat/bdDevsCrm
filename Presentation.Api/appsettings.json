{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=CrmDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/bdDevsCrm-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{CorrelationId}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5086",
      "https://localhost:7274"
    ],
    "AllowCredentials": true,
    "PreflightMaxAge": 3600
  },
  "AppSettings": {
    "Jwt": {
      "SecretKey": "your-super-secret-key-here",
      "Issuer": "bdDevsCrm",
      "Audience": "bdDevsCrm-clients",
      "AccessTokenExpiryMinutes": 60,
      "RefreshTokenExpiryDays": 7
    },
    "Password": {
      "SaltRounds": 12,
      "MinLength": 8,
      "MaxLength": 128,
      "MaxWrongAttempts": 5,
      "ExpiryDays": 90
    },
    "Cache": {
      "EnableDistributedCache": true,
      "UserCacheMinutes": 30,
      "MenuCacheMinutes": 60,
      "StaticDataHours": 24
    },
    "Audit": {
      "EnableAuditMiddleware": true,
      "QueueCapacity": 1000,
      "BatchSize": 50,
      "FlushIntervalSeconds": 5
    }
  }
}
