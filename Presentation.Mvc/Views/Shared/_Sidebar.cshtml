@{
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var isDashboard = string.Equals(currentPath, "/", StringComparison.OrdinalIgnoreCase)
        || currentPath.StartsWith("/Home", StringComparison.OrdinalIgnoreCase);
    var hrOperationPaths = new[] { "/Employee", "/Department", "/Branch", "/Designation", "/Shift" };
    var systemSetupPaths = new[] { "/Module", "/Menu", "/Group", "/Users", "/Company", "/Companies", "/Country", "/Thana", "/Workflow", "/AccessControl", "/AccessRestriction", "/AuditType", "/Holiday", "/MaritalStatus", "/Currency", "/CurrencyRate", "/BoardInstitute", "/ApproverType", "/ApproverHistory", "/DocumentTemplate", "/DocumentParameter", "/ApproverTypeToGroupMapping", "/DocumentType", "/PasswordHistory", "/Competencies", "/CompetencyLevel", "/ApproverOrder", "/ApproverDetails", "/AssignApprover", "/DocumentQueryMapping", "/DocumentParameterMapping", "/AuditTrail", "/AuditLog", "/AppsTokenInfo", "/AppsTransactionLog", "/SystemSettings", "/QueryAnalyzer", "/TokenBlacklist", "/Timesheet", "/Common" };
    var crmPaths = new[] { "/AgentType", "/LeadSource", "/LeadStatus", "/StudentStatus", "/Office", "/VisaType", "/Agent", "/Counselor", "/Lead", "/Student", "/Enquiry", "/FollowUp", "/Note", "/Task", "/PaymentMethod", "/ApplicantInfo", "/Course", "/Institute", "/InstituteType", "/IntakeMonth", "/IntakeYear", "/Month", "/Year", "/CourseIntake", "/ApplicantCourse", "/ApplicantReference", "/Application", "/AdditionalDocument", "/AdditionalInfo", "/EducationHistory", "/WorkExperience", "/PermanentAddress", "/PresentAddress", "/GmatInformation", "/IeltsInformation", "/ToeflInformation", "/OthersInformation", "/StatementOfPurpose" };
    bool IsCurrent(params string[] prefixes) => prefixes.Any(prefix => currentPath.StartsWith(prefix, StringComparison.OrdinalIgnoreCase));
    var isHrOperations = IsCurrent(hrOperationPaths);
    var isSystemSetup = IsCurrent(systemSetupPaths);
    var isCrm = IsCurrent(crmPaths);
}

