@{
    ViewData["Title"] = "Present Address Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header">
    <div>
        <h1 class="page-header__title">Present Address Management</h1>
        <p class="page-header__subtitle">Phase 3 applicant detail module for present address maintenance.</p>
        <div class="breadcrumb">
            <span class="breadcrumb__item">CRM</span>
            <span class="breadcrumb__item is-current">Present Address</span>
        </div>
    </div>
    <div class="page-header__actions">
        <button type="button" id="btnAddPresentAddress" class="btn btn--primary">Add Present Address</button>
        <button type="button" id="btnRefreshPresentAddress" class="btn btn--secondary">Refresh</button>
    </div>
</section>

<section class="table-shell">
    <div id="presentAddressGrid"></div>
</section>

<div id="presentAddressWindow" style="display:none;">
    <form id="presentAddressForm" class="form-layout form-layout--grid"></form>
    <div class="form-action-bar">
        <button type="button" id="btnCancelPresentAddress" class="btn btn--ghost">Cancel</button>
        <button type="button" id="btnSavePresentAddress" class="btn btn--primary">Save</button>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/crm/common/crmSimpleCrudFactory.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/presentaddress/presentAddressSettings.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/presentaddress/presentAddressSummary.js" asp-append-version="true"></script>
    <script src="~/js/modules/crm/presentaddress/presentAddressDetails.js" asp-append-version="true"></script>
}
